# Copy this file outside the repo or source it directly with local overrides:
#
#   source configs/long-range-tailnet-field.env.example
#   DRONE_HOST=pi@drone-name.tailnet.ts.net LOCAL_WFB_KEY=/path/to/gs.key \
#     scripts/prepare-long-range-tailnet-field.sh
#
# Existing runner note:
# - Tunnel/managed-stream scripts use WFB_KEY as the local GS-side key.
# - Duplex Linux-peer scripts use WFB_KEY as the remote drone-side key.
# The prep script keeps those separate as LOCAL_WFB_KEY and DRONE_WFB_KEY and
# writes concrete commands with the correct per-runner mapping.

DRONE_HOST=
DRONE_IFACE=wfb0
DRONE_REMOTE_PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
DRONE_WFB_KEY=/var/lib/arc/wfb/drone.key

LOCAL_WFB_KEY=
FIRMWARE=/tmp/rtl8812aefw.bin
RADIO_CONFIG=configs/radio-run-long-range-field.toml

# Arc tunnel defaults. Set LINK_ID=0x000001 and stock ports only when testing
# against an unmodified WFB-NG peer profile.
LINK_ID=0x000000
CHANNEL=165
BANDWIDTH_MHZ=20
TUN_RX_RADIO_PORT=3
TUN_TX_RADIO_PORT=4
LOCAL_IP=10.5.0.1
PEER_IP=10.5.0.2

# Conservative first-contact RF tuple. This passed at roughly 300 m during the
# 2026-05-18 range walk, but failed at roughly 350 m without improving antenna
# geometry. Start here for auth/control evidence, then raise video MCS/bitrate
# only after packet recovery and decrypt health are clean at the target
# distance.
MCS=0
FEC_K=2
FEC_N=8
DATA_LOAD_MCS=0
DATA_LOAD_FEC_K=2
DATA_LOAD_FEC_N=8
TX_MIN_INTERVAL_US=700
TX_BURST_LIMIT=8

# Field-tested on 2026-05-18. Use 0x20 as the default field gate. 0x28 was
# diagnostic only: it recovered some packets at 350 m but still failed and may
# exceed allowed EIRP depending on antenna gain.
TX_POWER_MODE=manual-index
TX_POWER_INDEX=0x20
TX_POWER_PATH=both

AIRTIME_MODE=tdd
AIRTIME_TDD_FIRST_WINDOW=rx
AIRTIME_TDD_RX_WINDOW_MS=1000
AIRTIME_TDD_TX_WINDOW_MS=1000
AIRTIME_TDD_GUARD_MS=100
AIRTIME_TDD_START_DELAY_MS=0

# WFB packet/auth side-load ports used by scripts/run-mac-wf-tun-profile-matrix.sh.
DATA_M2L_RADIO_PORT=6
DATA_L2M_RADIO_PORT=7
DATA_LOAD_EXPECTED_PAYLOADS=100
DATA_LOAD_MIN_M2L_UNIQUE=100
DATA_LOAD_MIN_L2M_UNIQUE=100
DATA_LOAD_COUNTER_SECONDS=30

# Raw duplex profile-matrix defaults.
M2L_RADIO_PORT=0
L2M_RADIO_PORT=1
M2L_MCS=0
L2M_MCS=0
M2L_FEC_K=2
M2L_FEC_N=12
L2M_FEC_K=2
L2M_FEC_N=12
M2L_PAYLOAD_INTERVAL_SEC=0.100
L2M_PAYLOAD_INTERVAL_SEC=0.040
M2L_EXPECTED_PAYLOADS=100
L2M_EXPECTED_PAYLOADS=100
SESSION_ACQUIRE_MODE=observed
DECRYPT_FAILURE_GATE=post-session
MAX_M2L_DECRYPT_FAILURES=0
MAX_L2M_DECRYPT_FAILURES=0

# Optional pinned key fingerprints. These are fingerprints of the specific key
# files, not a gs.key/drone.key equality check.
EXPECTED_LOCAL_WFB_KEY_SHA256=
EXPECTED_DRONE_WFB_KEY_SHA256=
